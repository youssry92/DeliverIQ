{
  "rewrites": [
    { "source": "/((?!tess/|tessdata/|assets/|.*\\.).*)", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/tessdata/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/tess/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
  ]
}
